{
  "name": "pallas",
  "version": "1.0.0",
  "description": "Pallas — local AI assistant",
  "main": "app.js",
  "scripts": {
    "start": "node server.js",
    "electron": "set ELECTRON_RUN_AS_NODE=&& node_modules\\electron\\dist\\electron.exe .",
    "dist": "electron-builder --win"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.pallas.app",
    "productName": "Pallas",
    "copyright": "© 2025 Pallas",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "app.js",
      "server.js",
      "public/**",
      "node_modules/**",
      "!node_modules/electron{,-builder,-winstaller,-updater,-download}/**",
      "!website/**",
      "!data/**",
      "!*.bat",
      "!.git/**"
    ],
    "asar": true
  }
}
